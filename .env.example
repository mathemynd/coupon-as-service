# Copy to .env.development (dev) and .env.test (test). Both are gitignored.
#
# For .env.test, set API_PASSWORD=testpass (tests default to "testpass" when
# process.env.API_PASSWORD is unset, and .env files are not exported to process.env).

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/coupon_service_development
API_PASSWORD=secret
NODE_ENV=development
PORT=3014
