model CouponUsage {
  id               Int      @id @default(autoincrement())
  created_date     DateTime @default(now())
  updated_date     DateTime @updatedAt
  is_deleted       Boolean  @default(false)

  code             String
  redemption_count Int
  redeemed_at      DateTime @default(now())
  metadata         Json?

  @@map("coupon_usages")
}
